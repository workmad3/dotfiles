export PROFILE_D="$HOME/.profile.d"

export PATH="$HOME/.local/bin:$PATH"

if [ -d $PROFILE_D ]; then
  for c in `ls $PROFILE_D/*`; do
    conf=$(basename $c)
    config_file=$PROFILE_D/$conf
    if [[ -x "$config_file" ]]; then
      export ${conf}=`$config_file`
    else
      export ${conf}=`cat $config_file`
    fi
  done
fi

